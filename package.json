{
  "name": "pagecast",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Slides that are real web pages — design decks with your AI agent, present in the browser, and share with a link.",
  "keywords": [
    "slides",
    "presentations",
    "slide-deck",
    "react",
    "cloudflare-pages",
    "pdf",
    "local-first",
    "ai-agents",
    "claude"
  ],
  "homepage": "https://github.com/az-hussain/pagecast#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/az-hussain/pagecast.git"
  },
  "bugs": {
    "url": "https://github.com/az-hussain/pagecast/issues"
  },
  "author": "Azhar Hussain",
  "license": "MIT",
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "postinstall": "node scripts/postinstall.mjs",
    "preview": "vite preview --port 4173",
    "doctor": "node scripts/doctor.mjs",
    "export": "node scripts/export-pdf.mjs",
    "publish": "node scripts/publish.mjs",
    "unpublish": "node scripts/unpublish.mjs",
    "new:slide": "node scripts/create-slide.mjs",
    "new:deck": "node scripts/create-deck.mjs",
    "edit:deck": "node scripts/edit-deck.mjs",
    "add:slide": "node scripts/add-slide.mjs",
    "remove:slide": "node scripts/remove-slide.mjs",
    "move:slide": "node scripts/move-slide.mjs"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.26.2",
    "simple-icons": "^16.21.0"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "@types/react": "^18.3.5",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^6.0.2",
    "playwright": "^1.47.0",
    "typescript": "^5.6.2",
    "vite": "^8.0.16"
  }
}
